<!DOCTYPE html>
<html lang="pl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<meta name="mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<title>SprzątApka</title>
<link href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;500;600;700&family=Playfair+Display:ital,wght@0,400;0,600;1,400&display=swap" rel="stylesheet">
<style>
/* ══════════════════════════════════════
   TOKENS
══════════════════════════════════════ */
:root {
  --bg:#0d0d18; --bg2:#131320; --bg3:#1a1a2e;
  --card:#181828; --card2:#1f1f35;
  --indigo:#4f4ecb; --indigo2:#6362d8; --indigo3:#3d3ca8;
  --indigo-gl:rgba(79,78,203,0.18);
  --rose:#e8a0b0; --rose2:#f0b8c5; --rose3:#d4788e;
  --rose-gl:rgba(232,160,176,0.15); --rose-gl2:rgba(232,160,176,0.08);
  --green:#5ecea0; --amber:#f0b858; --red:#e87070;
  --border:rgba(255,255,255,0.07); --border2:rgba(255,255,255,0.13);
  --t1:#f0eef8; --t2:#9896b8; --t3:#5a5878;
  --r:16px; --r2:12px;
}

/* ══════════════════════════════════════
   RESET
══════════════════════════════════════ */
*,*::before,*::after { box-sizing:border-box; margin:0; padding:0; -webkit-tap-highlight-color:transparent; }
html,body { height:100%; overflow:hidden; }
body { background:var(--bg); color:var(--t1); font-family:'Sora',sans-serif; -webkit-font-smoothing:antialiased; }
button { font-family:'Sora',sans-serif; cursor:pointer; }
input,select,textarea { font-family:'Sora',sans-serif; }
select option { background:#1a1a2e; }

/* ══════════════════════════════════════
   ROOT LAYOUT
   .app → flex column, full screen
   .view-area → flex:1, clips all views/subviews/modals
   .bnav → fixed height at bottom, never overlapped
══════════════════════════════════════ */
.app {
  max-width: 430px;
  height: 100dvh;
  margin: 0 auto;
  display: flex;
  flex-direction: column;
  background: var(--bg);
  overflow: hidden;
  position: relative;
}
.view-area {
  flex: 1;
  min-height: 0;
  position: relative;
  overflow: hidden;
}

/* ══════════════════════════════════════
   VIEWS  (fill view-area, stacked)
══════════════════════════════════════ */
.view {
  display: none;
  flex-direction: column;
  position: absolute;
  inset: 0;
  overflow: hidden;
  background: var(--bg);
}
.view.active { display: flex; }

/* ══════════════════════════════════════
   SUBVIEWS  (slide in from right)
══════════════════════════════════════ */
.subview {
  display: flex;
  flex-direction: column;
  position: absolute;
  inset: 0;
  z-index: 50;
  background: var(--bg);
  transform: translateX(100%);
  transition: transform .28s cubic-bezier(.32,0,.12,1);
  overflow: hidden;
  pointer-events: none;
}
.subview.open {
  transform: translateX(0);
  pointer-events: auto;
}

/* ══════════════════════════════════════
   MODALS  (bottom sheet)
══════════════════════════════════════ */
.modal-overlay {
  display: none;
  position: absolute;
  inset: 0;
  z-index: 200;
  background: rgba(0,0,0,0.65);
  align-items: flex-end;
}
.modal-overlay.open { display: flex; }
.modal-sheet {
  background: var(--bg3);
  border-radius: 24px 24px 0 0;
  width: 100%;
  max-height: 90%;
  overflow-y: auto;
  padding-bottom: env(safe-area-inset-bottom, 20px);
  animation: sheetUp .26s cubic-bezier(.32,0,.12,1);
}
@keyframes sheetUp { from { transform:translateY(100%); } to { transform:translateY(0); } }
.modal-hd {
  padding: 20px 20px 14px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-bottom: 1px solid var(--border);
  position: sticky;
  top: 0;
  background: var(--bg3);
  z-index: 1;
}
.modal-title { font-family:'Playfair Display',serif; font-size:18px; }
.modal-close {
  background: var(--card2);
  border: 1px solid var(--border2);
  color: var(--t2);
  border-radius: 8px;
  padding: 7px 14px;
  font-size: 13px;
}
.modal-close:active { background: var(--card); }

/* ══════════════════════════════════════
   BOTTOM NAV
══════════════════════════════════════ */
.bnav {
  height: 64px;
  flex-shrink: 0;
  display: flex;
  background: rgba(10,10,22,.98);
  backdrop-filter: blur(24px);
  -webkit-backdrop-filter: blur(24px);
  border-top: 1px solid var(--border);
  padding-bottom: env(safe-area-inset-bottom, 0px);
}
.ni {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 3px;
  cursor: pointer;
  padding: 8px 0;
  position: relative;
  transition: opacity .15s;
}
.ni svg { width:22px; height:22px; color:var(--t3); transition:color .18s; }
.ni .nl { font-size:9px; font-weight:700; letter-spacing:.6px; text-transform:uppercase; color:var(--t3); transition:color .18s; }
.ni.on svg { color:var(--rose); filter:drop-shadow(0 0 5px rgba(232,160,176,.45)); }
.ni.on .nl { color:var(--rose); }
.ni.on::before {
  content: '';
  position: absolute;
  top: 0; left: 50%;
  transform: translateX(-50%);
  width: 32px; height: 2px;
  background: var(--rose);
  border-radius: 0 0 4px 4px;
}
.ni:active { opacity: .7; }

/* ══════════════════════════════════════
   HEADERS
══════════════════════════════════════ */
.hdr {
  flex-shrink: 0;
  padding: 52px 20px 20px;
  background: linear-gradient(155deg, #1f1d48 0%, #181630 55%, var(--bg3) 100%);
  position: relative;
  overflow: hidden;
  isolation: isolate;
}
.hdr::after {
  content: '';
  position: absolute;
  top: -50px; right: -50px;
  width: 220px; height: 220px;
  background: radial-gradient(circle, rgba(232,160,176,.09) 0%, transparent 65%);
  pointer-events: none;
  z-index: 0;
}
.hdr-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  position: relative;
  z-index: 1;
}
.hdr-logo { display:flex; align-items:center; gap:10px; }
.hdr-logo svg { width:30px; height:30px; flex-shrink:0; }
.hdr-brand { display:flex; flex-direction:column; line-height:1.2; }
.hdr-brand-name { font-family:'Playfair Display',serif; font-size:17px; color:var(--t1); }
.hdr-brand-sub { font-size:10px; color:var(--rose); text-transform:uppercase; letter-spacing:1px; font-weight:600; }
.hdr-btn {
  background: var(--rose-gl);
  border: 1px solid rgba(232,160,176,.28);
  color: var(--rose2);
  border-radius: 10px;
  padding: 9px 15px;
  font-size:13px;
  font-weight: 600;
  position: relative;
  z-index: 1;
  transition: background .18s;
}
.hdr-btn:active { background: rgba(232,160,176,.28); }
.hdr-title {
  font-family: 'Playfair Display', serif;
  font-size: 23px;
  color: var(--t1);
  margin-top: 14px;
  position: relative;
  z-index: 1;
}
.hdr-sub {
  font-size: 12px;
  color: var(--t2);
  margin-top: 3px;
  position: relative;
  z-index: 1;
}

/* SUB-HEADER (inside subviews) */
.sub-hdr {
  flex-shrink: 0;
  padding: 52px 20px 20px;
  background: linear-gradient(155deg, #1f1d48 0%, #181630 55%, var(--bg3) 100%);
  position: relative;
  overflow: hidden;
  isolation: isolate;
}
.sub-hdr::after {
  content: '';
  position: absolute;
  top: -50px; right: -50px;
  width: 180px; height: 180px;
  background: radial-gradient(circle, rgba(232,160,176,.09) 0%, transparent 65%);
  pointer-events: none;
  z-index: 0;
}
.back-btn {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  background: none;
  border: none;
  color: var(--t2);
  font-size: 14px;
  font-weight: 500;
  margin-bottom: 12px;
  padding: 4px 0;
  position: relative;
  z-index: 1;
  transition: color .15s;
}
.back-btn:active { color: var(--t1); }
.sub-chip {
  font-size: 10px;
  font-weight: 700;
  color: var(--rose);
  text-transform: uppercase;
  letter-spacing: .8px;
  margin-bottom: 6px;
  display: block;
  position: relative;
  z-index: 1;
}
.sub-title {
  font-family: 'Playfair Display', serif;
  font-size: 22px;
  color: var(--t1);
  position: relative;
  z-index: 1;
}
.sub-sub {
  font-size: 12px;
  color: var(--t2);
  margin-top: 4px;
  position: relative;
  z-index: 1;
}

/* ══════════════════════════════════════
   SCROLL AREA
══════════════════════════════════════ */
.scroll {
  flex: 1;
  overflow-y: auto;
  overflow-x: hidden;
  -webkit-overflow-scrolling: touch;
  scrollbar-width: none;
  padding-bottom: 16px;
}
.scroll::-webkit-scrollbar { display: none; }

/* ══════════════════════════════════════
   DATE STRIP
══════════════════════════════════════ */
.date-strip {
  display: flex;
  gap: 8px;
  padding: 12px 16px 10px;
  overflow-x: auto;
  scrollbar-width: none;
  flex-shrink: 0;
  background: var(--bg3);
}
.date-strip::-webkit-scrollbar { display: none; }
.dp {
  min-width: 48px;
  height: 62px;
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: 14px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 1px;
  cursor: pointer;
  flex-shrink: 0;
  transition: all .18s;
  user-select: none;
}
.dp.on {
  background: var(--indigo);
  border-color: var(--indigo2);
  box-shadow: 0 4px 16px rgba(79,78,203,.4);
}
.dp .dw { font-size:9px; font-weight:700; color:var(--t3); text-transform:uppercase; letter-spacing:.5px; }
.dp .dd { font-size:18px; font-weight:700; color:var(--t1); }
.dp .dot { width:4px; height:4px; border-radius:50%; background:var(--rose); margin-top:1px; }
.dp.on .dw, .dp.on .dd { color:#fff; }
.dp.on .dot { background:rgba(255,255,255,.6); }

/* ══════════════════════════════════════
   SECTION LABEL
══════════════════════════════════════ */
.slbl {
  font-size: 10px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 1.3px;
  color: var(--t3);
  padding: 14px 16px 6px;
}

/* ══════════════════════════════════════
   ORDER CARDS
══════════════════════════════════════ */
.olist { padding: 0 12px; display: flex; flex-direction: column; gap: 9px; }
.oc {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: var(--r);
  padding: 14px 12px 14px 0;
  display: flex;
  cursor: pointer;
  transition: transform .15s, background .15s;
  position: relative;
  overflow: hidden;
  user-select: none;
}
.oc:active { transform: scale(.98); background: var(--card2); }
.oc-bar { width:3px; border-radius:0 3px 3px 0; margin-right:12px; flex-shrink:0; align-self:stretch; }
.oc.pl .oc-bar { background:var(--t3); }
.oc.co .oc-bar { background:var(--indigo2); }
.oc.ip .oc-bar { background:var(--amber); }
.oc.dn .oc-bar { background:var(--green); }
.oc-time { min-width:46px; flex-shrink:0; display:flex; flex-direction:column; align-items:center; padding-top:2px; margin-right:4px; }
.oc-time .t { font-size:13px; font-weight:700; line-height:1; }
.oc-time .te { font-size:10px; color:var(--t3); margin-top:2px; }
.oc-body { flex:1; min-width:0; }
.oc-client { font-size:14px; font-weight:600; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
.oc-desc { font-size:12px; color:var(--t2); margin-top:2px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
.oc-meta { display:flex; gap:5px; margin-top:7px; flex-wrap:wrap; align-items:center; }
.oc-arr { color:var(--t3); font-size:18px; align-self:center; margin-left:6px; flex-shrink:0; }

/* ══════════════════════════════════════
   BADGES
══════════════════════════════════════ */
.badge { font-size:9px; font-weight:800; padding:3px 8px; border-radius:20px; letter-spacing:.4px; text-transform:uppercase; }
.badge.pl { background:rgba(90,88,120,.3); color:var(--t2); }
.badge.co { background:var(--indigo-gl); color:#a0a0ff; }
.badge.ip { background:rgba(240,184,88,.18); color:var(--amber); }
.badge.dn { background:rgba(94,206,160,.15); color:var(--green); }
.badge.rose { background:var(--rose-gl); color:var(--rose2); }

/* ══════════════════════════════════════
   EMPTY STATE
══════════════════════════════════════ */
.empty { text-align:center; padding:48px 20px; }
.empty .ei { font-size:44px; margin-bottom:10px; }
.empty .et { font-size:14px; color:var(--t2); line-height:1.5; }
.empty .ea {
  margin-top:16px;
  display:inline-block;
  background:var(--rose-gl);
  border:1px solid rgba(232,160,176,.25);
  color:var(--rose2);
  border-radius:10px;
  padding:10px 18px;
  font-size:13px;
  font-weight:600;
  cursor:pointer;
}

/* ══════════════════════════════════════
   INFO CARDS
══════════════════════════════════════ */
.icard { background:var(--card); border:1px solid var(--border); border-radius:var(--r); overflow:hidden; margin:0 12px; }
.icard + .icard { margin-top:10px; }
.icard-hd {
  padding:12px 15px;
  font-size:10px;
  font-weight:700;
  text-transform:uppercase;
  letter-spacing:1px;
  color:var(--t3);
  border-bottom:1px solid var(--border);
  display:flex;
  align-items:center;
  justify-content:space-between;
}
.icard-edit { font-size:12px; color:var(--rose); cursor:pointer; font-weight:600; text-transform:none; letter-spacing:0; }
.irow { display:flex; justify-content:space-between; align-items:center; padding:11px 15px; border-bottom:1px solid var(--border); gap:10px; }
.irow:last-child { border-bottom:none; }
.irow.tap { cursor:pointer; transition:background .15s; }
.irow.tap:active { background:var(--card2); }
.ik { font-size:12px; color:var(--t2); flex-shrink:0; }
.iv { font-size:13px; color:var(--t1); font-weight:500; text-align:right; word-break:break-word; }
.iv.code { background:var(--indigo-gl); color:#a0a0ff; padding:3px 10px; border-radius:8px; font-family:monospace; font-size:16px; font-weight:700; letter-spacing:2px; }
.iv.rose { color:var(--rose); }
.iv.blue { color:#60a5fa; }

/* ══════════════════════════════════════
   STATUS SELECTOR
══════════════════════════════════════ */
.status-grid {
  display:grid; grid-template-columns:1fr 1fr; gap:8px;
  padding:14px; margin:0 12px;
  background:var(--card); border:1px solid var(--border); border-radius:var(--r);
}
.sg-lbl { grid-column:1/-1; font-size:10px; font-weight:700; text-transform:uppercase; letter-spacing:1px; color:var(--t3); margin-bottom:2px; }
.sbtn {
  padding:13px 6px; border-radius:var(--r2); border:2px solid var(--border);
  background:var(--bg3); color:var(--t2); font-size:10px; font-weight:800;
  text-align:center; cursor:pointer; text-transform:uppercase; letter-spacing:.4px;
  transition:all .16s; user-select:none;
}
.sbtn .si { font-size:20px; display:block; margin-bottom:4px; }
.sbtn:active { transform:scale(.96); }
.sbtn.a-pl { background:rgba(90,88,120,.2); border-color:var(--t3); color:var(--t1); }
.sbtn.a-co { background:var(--indigo-gl); border-color:var(--indigo2); color:#a0a0ff; }
.sbtn.a-ip { background:rgba(240,184,88,.15); border-color:var(--amber); color:var(--amber); }
.sbtn.a-dn { background:rgba(94,206,160,.12); border-color:var(--green); color:var(--green); }

/* ══════════════════════════════════════
   BIG BUTTONS
══════════════════════════════════════ */
.bigbtn {
  margin:0 12px; width:calc(100% - 24px);
  padding:17px; border-radius:var(--r);
  font-size:14px; font-weight:700;
  border:none; display:flex; align-items:center; justify-content:center; gap:10px;
  transition:all .18s; letter-spacing:.3px; user-select:none;
}
.bigbtn:active { transform:scale(.97); }
.bigbtn.indigo { background:linear-gradient(135deg,var(--indigo3),var(--indigo2)); color:#fff; box-shadow:0 6px 20px rgba(79,78,203,.35); }
.bigbtn.rose-btn { background:linear-gradient(135deg,#c46880,var(--rose)); color:#fff; box-shadow:0 6px 20px rgba(232,160,176,.3); }
.bigbtn.ghost { background:var(--card); border:1px solid var(--border2); color:var(--t2); opacity:.6; pointer-events:none; }
.bigbtn.danger { background:rgba(232,112,112,.12); border:1px solid rgba(232,112,112,.25); color:var(--red); }

/* ══════════════════════════════════════
   PHOTO SECTION
══════════════════════════════════════ */
.photo-card { margin:0 12px; background:var(--card); border:1px solid var(--border); border-radius:var(--r); overflow:hidden; }
.photo-grid { display:grid; grid-template-columns:1fr 1fr; gap:1px; background:var(--border); }
.pb {
  background:var(--bg3); padding:16px 10px;
  display:flex; flex-direction:column; align-items:center; gap:6px;
  cursor:pointer; min-height:84px; justify-content:center; transition:background .15s;
  user-select:none;
}
.pb:active { background:var(--card2); }
.pb .pi { font-size:24px; line-height:1; }
.pb .pl { font-size:12px; font-weight:700; color:var(--t1); }
.pb .pc { font-size:10px; color:var(--t3); }
.pb.has-rose { background:rgba(232,160,176,.06); }
.pb.has-rose .pl { color:var(--rose2); }
.thumbs { padding:10px; display:flex; gap:7px; overflow-x:auto; scrollbar-width:none; }
.thumbs::-webkit-scrollbar { display:none; }
.thumb {
  width:62px; height:62px; border-radius:10px; background:var(--bg3);
  border:1px solid var(--border); flex-shrink:0;
  display:flex; align-items:center; justify-content:center; font-size:22px;
  position:relative; overflow:hidden;
}
.thumb .tl { position:absolute; bottom:0; left:0; right:0; text-align:center; font-size:7px; font-weight:800; text-transform:uppercase; background:rgba(0,0,0,.6); color:rgba(255,255,255,.8); padding:2px; }
.thumb.add { border:2px dashed var(--t3); color:var(--t3); font-size:20px; }

/* ══════════════════════════════════════
   MAP BUTTON
══════════════════════════════════════ */
.map-btn {
  display:flex; align-items:center; gap:10px;
  background:rgba(96,165,250,.1); border:1px solid rgba(96,165,250,.2);
  border-radius:var(--r2); padding:13px 14px;
  cursor:pointer; margin:0 12px; text-decoration:none;
  transition:background .15s;
}
.map-btn:active { background:rgba(96,165,250,.18); }
.map-ico { font-size:20px; flex-shrink:0; }
.map-txt .mt1 { font-size:13px; font-weight:600; color:#93c5fd; }
.map-txt .mt2 { font-size:11px; color:var(--t2); margin-top:1px; }
.map-arr { color:#60a5fa; font-size:15px; margin-left:auto; }

/* ══════════════════════════════════════
   CLIENT CARDS
══════════════════════════════════════ */
.clist { padding:0 12px; display:flex; flex-direction:column; gap:9px; }
.cc {
  background:var(--card); border:1px solid var(--border); border-radius:var(--r);
  padding:13px; display:flex; align-items:center; gap:12px;
  cursor:pointer; transition:transform .15s, background .15s;
  user-select:none;
}
.cc:active { transform:scale(.98); background:var(--card2); }
.cc-av {
  width:44px; height:44px; border-radius:14px;
  display:flex; align-items:center; justify-content:center;
  font-family:'Playfair Display',serif; font-size:16px; font-weight:600;
  color:#fff; flex-shrink:0;
}
.cc-av.ind { background:linear-gradient(135deg,var(--indigo3),var(--indigo2)); }
.cc-av.ros { background:linear-gradient(135deg,#c46880,var(--rose)); }
.cc-info { flex:1; min-width:0; }
.cc-name { font-size:14px; font-weight:600; }
.cc-addr { font-size:12px; color:var(--t2); margin-top:1px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
.cc-tags { display:flex; gap:5px; margin-top:5px; flex-wrap:wrap; }
.tag { font-size:9px; font-weight:800; padding:2px 7px; border-radius:20px; text-transform:uppercase; letter-spacing:.4px; }
.tag.rose { background:var(--rose-gl); color:var(--rose2); }
.tag.blue { background:var(--indigo-gl); color:#a0a0ff; }
.tag.green { background:rgba(94,206,160,.12); color:var(--green); }

/* ══════════════════════════════════════
   SEARCH
══════════════════════════════════════ */
.search-wrap { padding:0 12px 12px; background:linear-gradient(to bottom,var(--bg3),var(--bg2)); flex-shrink:0; }
.search-inner { position:relative; }
.search-ico { position:absolute; left:13px; top:50%; transform:translateY(-50%); font-size:14px; pointer-events:none; }
.search-input {
  width:100%; background:rgba(255,255,255,.06); border:1px solid var(--border2);
  border-radius:var(--r2); padding:12px 12px 12px 38px;
  color:var(--t1); font-size:14px; outline:none;
}
.search-input::placeholder { color:var(--t3); }
.search-input:focus { border-color:rgba(232,160,176,.4); }

/* ══════════════════════════════════════
   TEAM
══════════════════════════════════════ */
.team-list { padding:0 12px; display:flex; flex-direction:column; gap:9px; }
.tc { background:var(--card); border:1px solid var(--border); border-radius:var(--r); padding:14px; display:flex; align-items:center; gap:12px; }
.tc-av { width:46px; height:46px; border-radius:50%; display:flex; align-items:center; justify-content:center; font-family:'Playfair Display',serif; font-size:17px; color:#fff; flex-shrink:0; }
.tc-info { flex:1; }
.tc-name { font-size:14px; font-weight:600; }
.tc-role { font-size:12px; color:var(--t2); margin-top:1px; }
.tc-meta { display:flex; gap:6px; margin-top:5px; align-items:center; }
.online-dot { width:6px; height:6px; border-radius:50%; background:var(--green); box-shadow:0 0 5px rgba(94,206,160,.5); }

/* ══════════════════════════════════════
   STATS
══════════════════════════════════════ */
.stats-row { display:grid; grid-template-columns:1fr 1fr 1fr; gap:8px; padding:0 12px; }
.stat { background:var(--card); border:1px solid var(--border); border-radius:var(--r2); padding:14px 8px; text-align:center; }
.stat-num { font-size:24px; font-weight:700; font-family:'Playfair Display',serif; color:var(--t1); }
.stat-lbl { font-size:9px; color:var(--t3); text-transform:uppercase; letter-spacing:.5px; font-weight:700; margin-top:3px; }
.stat.rs .stat-num { color:var(--rose); }
.stat.gn .stat-num { color:var(--green); }

/* ══════════════════════════════════════
   OFFICE GRID
══════════════════════════════════════ */
.office-grid { display:grid; grid-template-columns:1fr 1fr; gap:9px; padding:0 12px; }
.og { background:var(--card); border:1px solid var(--border); border-radius:var(--r); padding:16px 13px; display:flex; flex-direction:column; gap:7px; cursor:pointer; transition:all .16s; }
.og.full { grid-column:1/-1; flex-direction:row; align-items:center; gap:14px; }
.og:active { transform:scale(.97); }
.og-ico { font-size:24px; line-height:1; }
.og-name { font-size:13px; font-weight:700; color:var(--t1); }
.og-desc { font-size:11px; color:var(--t2); line-height:1.4; }
.og.sos-t { background:linear-gradient(135deg,rgba(232,112,112,.16),rgba(180,60,60,.1)); border-color:rgba(232,112,112,.22); }
.og.rose-t { background:var(--rose-gl2); border-color:rgba(232,160,176,.18); }
.og.ind-t { background:var(--indigo-gl); border-color:rgba(79,78,203,.22); }

/* ══════════════════════════════════════
   SOS PULSE
══════════════════════════════════════ */
.sos-pulse {
  width:46px; height:46px; border-radius:50%;
  background:linear-gradient(135deg,#b91c1c,#ef4444);
  display:flex; align-items:center; justify-content:center;
  font-size:20px; border:none; flex-shrink:0;
  animation:sosring 2.2s infinite;
  transition:transform .15s;
}
.sos-pulse:active { transform:scale(.88); }
@keyframes sosring {
  0%,100% { box-shadow:0 0 0 0 rgba(239,68,68,.45); }
  50%      { box-shadow:0 0 0 14px rgba(239,68,68,0); }
}

/* ══════════════════════════════════════
   NOTES
══════════════════════════════════════ */
.note-item { background:var(--card); border:1px solid var(--border); border-radius:var(--r2); padding:13px 14px; margin:0 12px; cursor:pointer; transition:background .15s; }
.note-item + .note-item { margin-top:8px; }
.note-item:active { background:var(--card2); }
.note-t { font-size:13px; font-weight:600; }
.note-b { font-size:12px; color:var(--t2); margin-top:3px; line-height:1.5; }
.note-d { font-size:10px; color:var(--t3); margin-top:5px; }

/* ══════════════════════════════════════
   FORMS
══════════════════════════════════════ */
.form-body { padding:16px 20px 8px; display:flex; flex-direction:column; gap:14px; }
.field { display:flex; flex-direction:column; gap:6px; }
.field label { font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:1px; color:var(--t3); }
.field input, .field select, .field textarea {
  background:var(--card); border:1px solid var(--border2); border-radius:var(--r2);
  padding:13px 14px; color:var(--t1); font-size:14px;
  outline:none; width:100%; transition:border-color .2s;
}
.field input:focus, .field select:focus, .field textarea:focus { border-color:var(--rose); }
.field textarea { resize:none; min-height:72px; line-height:1.5; }
.field input::placeholder, .field textarea::placeholder { color:var(--t3); }
.form-row { display:grid; grid-template-columns:1fr 1fr; gap:10px; }
.form-actions { padding:12px 20px 20px; display:flex; flex-direction:column; gap:8px; }

/* ══════════════════════════════════════
   TOAST
══════════════════════════════════════ */
.toast {
  position:absolute; bottom:14px; left:50%;
  transform:translateX(-50%) translateY(12px);
  background:var(--card2); border:1px solid var(--border2);
  border-radius:12px; padding:11px 20px;
  font-size:13px; font-weight:600; color:var(--t1);
  z-index:999; opacity:0; transition:opacity .25s, transform .25s;
  white-space:nowrap; pointer-events:none;
  max-width:calc(100% - 32px);
}
.toast.show { opacity:1; transform:translateX(-50%) translateY(0); }
.toast.success { border-color:rgba(94,206,160,.4); color:var(--green); }
.toast.error { border-color:rgba(232,112,112,.4); color:var(--red); }

/* ══════════════════════════════════════
   DELETE ROW
══════════════════════════════════════ */
.delete-row { padding:6px 12px 4px; display:flex; justify-content:center; }
.del-btn { background:none; border:none; color:var(--t3); font-size:12px; font-weight:600; cursor:pointer; padding:8px 16px; transition:color .15s; }
.del-btn:active { color:var(--red); }

/* UTILITY */
.gap { height:10px; }
.gap2 { height:16px; }
.mt0 { margin:0; }

/* ANIMATIONS */
@keyframes fadeUp { from{opacity:0;transform:translateY(12px)} to{opacity:1;transform:translateY(0)} }
.view.active > * { animation:fadeUp .22s ease both; }
.view.active > *:nth-child(1){animation-delay:.00s}
.view.active > *:nth-child(2){animation-delay:.04s}
.view.active > *:nth-child(3){animation-delay:.07s}
.view.active > *:nth-child(4){animation-delay:.10s}
</style>
</head>
