════════════════════════════════════════ */
let _pinBuffer = '';

function pinPress(d) {
  if (_pinBuffer.length >= 4) return;
  _pinBuffer += d;
  updatePinDots();
  if (_pinBuffer.length === 4) {
    setTimeout(() => {
      if (_pinBuffer === DB.getPin()) {
        unlockApp();
      } else {
        document.getElementById('pin-error').textContent = 'Nieprawidłowy PIN. Spróbuj ponownie.';
        _pinBuffer = '';
        updatePinDots();
        document.querySelectorAll('.pin-dot').forEach(el => {
          el.style.background = 'var(--red)';
          el.style.borderColor = 'var(--red)';
        });
        setTimeout(() => {
          document.getElementById('pin-error').textContent = '';
          updatePinDots();
        }, 600);
      }
    }, 100);
  }
}

function pinDel() {
  _pinBuffer = _pinBuffer.slice(0, -1);
  updatePinDots();
  document.getElementById('pin-error').textContent = '';
}

function pinBypass() { unlockApp(); } // dev shortcut — usuń w produkcji

function updatePinDots() {
  for (let i = 0; i < 4; i++) {
    const el = document.getElementById('pd'+i);
    el.className = 'pin-dot' + (i < _pinBuffer.length ? ' filled' : '');
    el.style.background = ''; el.style.borderColor = '';
  }
}

function unlockApp() {
  const ls = document.getElementById('lock-screen');
  ls.style.transition = 'opacity .3s';
  ls.style.opacity = '0';
  setTimeout(() => { ls.style.display = 'none'; scheduleRabbit(); }, 300);
}

function changePIN() {
  const newPin = prompt('Wpisz nowy 4-cyfrowy PIN:');
  if (!newPin || !/^\d{4}$/.test(newPin)) { toast('PIN musi mieć dokładnie 4 cyfry', 'error'); return; }
  DB.setPin(newPin);
  toast('✓ PIN zmieniony', 'success');
}

