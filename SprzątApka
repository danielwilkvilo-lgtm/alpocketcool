<script>
'use strict';
/* ════════════════════════════════════════
   DATA LAYER — localStorage
   Każda funkcja to jeden punkt wymiany na Supabase
════════════════════════════════════════ */
const DB = {
  _get(k)    { try{ return JSON.parse(localStorage.getItem(k)||'[]'); }catch{ return []; } },
  _set(k,v)  { localStorage.setItem(k, JSON.stringify(v)); },

  getClients()         { return this._get('co_clients'); },
  getClient(id)        { return this.getClients().find(c=>c.id===id)||null; },
  addClient(d)         { const a=this.getClients(); d.id='c_'+Date.now(); d.createdAt=new Date().toISOString(); a.push(d); this._set('co_clients',a); return d; },
  updateClient(id,d)   { this._set('co_clients', this.getClients().map(c=>c.id===id?{...c,...d}:c)); },
  deleteClient(id)     { this._set('co_clients', this.getClients().filter(c=>c.id!==id)); this._set('co_orders', this.getOrders().filter(o=>o.clientId!==id)); },

  getOrders()          { return this._get('co_orders'); },
  getOrder(id)         { return this.getOrders().find(o=>o.id===id)||null; },
  getOrdersByDate(d)   {
    return this.getOrders()
      .filter(o => o.date === d)
      .sort((a, b) => {
        const norm = t => { const p = (t||'00:00').split(':'); return p[0].padStart(2,'0') + ':' + (p[1]||'00'); };
        return norm(a.time).localeCompare(norm(b.time));
      });
  },
  getOrdersByClient(ci){ return this.getOrders().filter(o=>o.clientId===ci).sort((a,b)=>b.date.localeCompare(a.date)); },
  addOrder(d)          { const a=this.getOrders(); d.id='o_'+Date.now(); d.createdAt=new Date().toISOString(); a.push(d); this._set('co_orders',a); return d; },
  updateOrder(id,d)    { this._set('co_orders', this.getOrders().map(o=>o.id===id?{...o,...d}:o)); },
  deleteOrder(id)      { this._set('co_orders', this.getOrders().filter(o=>o.id!==id)); },

  getNotes()           { return this._get('co_notes'); },
  addNote(d)           { const a=this.getNotes(); d.id='n_'+Date.now(); d.createdAt=new Date().toISOString(); a.unshift(d); this._set('co_notes',a); return d; },
  deleteNote(id)       { this._set('co_notes', this.getNotes().filter(n=>n.id!==id)); }
};

/* ════════════════════════════════════════
   HELPERS
════════════════════════════════════════ */
const STATUS = {
  pl:{ label:'Planowane',    cls:'pl', icon:'📅' },
  co:{ label:'Potwierdzone', cls:'co', icon:'✅' },
  ip:{ label:'W trakcie',    cls:'ip', icon:'🔄' },
  dn:{ label:'Zakończone',   cls:'dn', icon:'🏁' }
};
const STATUS_NEXT = { pl:'co', co:'ip', ip:'dn', dn:'dn' };
const MONTHS_PL = ['stycznia','lutego','marca','kwietnia','maja','czerwca','lipca','sierpnia','września','października','listopada','grudnia'];

function todayStr() {
  const d = new Date();
  return `${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,'0')}-${String(d.getDate()).padStart(2,'0')}`;
}
function datePL(str) {
  if (!str || typeof str !== 'string') return '—';
  const parts = str.split('-');
  if (parts.length !== 3) return str;
  const [y, m, d] = parts;
  const mi = parseInt(m, 10) - 1;
  if (mi < 0 || mi > 11) return str;
  return `${parseInt(d, 10)} ${MONTHS_PL[mi]} ${y}`;
}
function initials(name) {
  return (name||'?').split(' ').filter(Boolean).slice(0,2).map(w=>w[0].toUpperCase()).join('');
}
function avatarCls(name) {
  return [...(name||'')].reduce((s,c)=>s+c.charCodeAt(0),0)%2===0 ? 'ros' : 'ind';
}
function esc(s) {
  return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

let _selectedDate = todayStr();
let _currentOrderId = null;
let _currentClientId = null;

/* ════════════════════════════════════════
   SEED — demo data (only on first visit)
════════════════════════════════════════ */
function seedIfEmpty() {
  if (DB.getClients().length) return;
  const c1 = DB.addClient({ name:'Maria Zientek', address:'ul. Lipowa 12/4, Warszawa', phone:'+48 602 111 222', intercom:'1234#', notes:'Czarny kot — nie wypuszczać! Gniazdko w kuchni nie działa.' });
  const c2 = DB.addClient({ name:'Janusz Kaczmarek', address:'ul. Nowa 5, Warszawa', phone:'+48 500 200 300', intercom:'', notes:'Biuro, piętro 2. Klucz u sekretarki.' });
  const c3 = DB.addClient({ name:'Aleksander Pietruk', address:'ul. Piaskowa 33/2, Warszawa', phone:'+48 601 333 444', intercom:'5678#', notes:'' });
  const today = todayStr();
  const tom   = new Date(Date.now()+86400000).toISOString().slice(0,10);
  DB.addOrder({ clientId:c1.id, date:today, time:'08:00', status:'co', desc:'Sprzątanie generalne mieszkania 3-pokojowego. Uwaga na łazienkę i kuchnię.' });
  DB.addOrder({ clientId:c2.id, date:today, time:'11:30', status:'ip', desc:'Biuro — piętro 2.' });
  DB.addOrder({ clientId:c3.id, date:today, time:'15:00', status:'pl', desc:'Sprzątanie po remoncie.' });
  DB.addOrder({ clientId:c1.id, date:tom,   time:'09:00', status:'co', desc:'Cotygodniowe sprzątanie.' });
  DB.addNote({ title:'Wi-Fi u Marii Zientek',  body:'Sieć: MariaDom · Hasło: kwiatki2024' });
  DB.addNote({ title:'Cennik 2026', body:'1-pok. 180 zł · 2-pok. 240 zł · 3-pok. 300 zł' });
}

/* ════════════════════════════════════════
   RENDER: DATE STRIP
════════════════════════════════════════ */
function renderDateStrip() {
  const strip = document.getElementById('date-strip');
  const DAYS  = ['Nd','Pn','Wt','Śr','Cz','Pt','Sb'];
  const today = new Date(); today.setHours(0,0,0,0);
  const allDates = new Set(DB.getOrders().map(o=>o.date));
  let html = '';
  for (let i = -1; i < 14; i++) {
    const d  = new Date(today); d.setDate(today.getDate()+i);
    const ds = d.toISOString().slice(0,10);
    const on = ds === _selectedDate ? ' on' : '';
    html += `<div class="dp${on}" onclick="selectDate('${ds}')">
      <span class="dw">${DAYS[d.getDay()]}</span>
      <span class="dd">${d.getDate()}</span>
      ${allDates.has(ds) ? '<span class="dot"></span>' : ''}
    </div>`;
  }
  strip.innerHTML = html;
}

function selectDate(ds) {
  _selectedDate = ds;
  renderDateStrip();
  renderOrders();
}

/* ════════════════════════════════════════
   RENDER: ORDERS
════════════════════════════════════════ */
function renderOrders() {
  const list   = document.getElementById('order-list');
  const orders = DB.getOrdersByDate(_selectedDate);
  const today  = todayStr();
  const tom    = new Date(Date.now()+86400000).toISOString().slice(0,10);
  const dayLabel = _selectedDate===today ? 'Dziś' : _selectedDate===tom ? 'Jutro' : datePL(_selectedDate);

  document.getElementById('sched-lbl').textContent = `${dayLabel} — ${orders.length} ${orders.length===1?'zlecenie':orders.length<5?'zlecenia':'zleceń'}`;
  const allToday = DB.getOrdersByDate(today);
  document.getElementById('sched-sub').textContent = `${datePL(today)} · ${allToday.length} dziś`;

  if (!orders.length) {
    list.innerHTML = `<div class="empty"><div class="ei">📭</div><div class="et">Brak zleceń na ten dzień</div><div class="ea" onclick="openModal('modal-order')">＋ Dodaj zlecenie</div></div>`;
    return;
  }
  list.innerHTML = orders.map(o => {
    const cl = DB.getClient(o.clientId);
    const s  = STATUS[o.status]||STATUS.pl;
    return `<div class="oc ${s.cls}" onclick="openOrder('${o.id}')">
      <div class="oc-bar"></div>
      <div class="oc-time"><span class="t">${esc(o.time||'—')}</span></div>
      <div class="oc-body">
        <div class="oc-client">${esc(cl ? cl.name : 'Nieznany klient')}</div>
        <div class="oc-desc">${esc(o.desc||'Brak opisu')}</div>
        <div class="oc-meta"><span class="badge ${s.cls}">${s.label}</span></div>
      </div>
      <div class="oc-arr">›</div>
    </div>`;
  }).join('');
}

/* ════════════════════════════════════════
   RENDER: CLIENTS
════════════════════════════════════════ */
function renderClients() {
  const q    = (document.getElementById('client-search')?.value||'').toLowerCase();
  let clients = DB.getClients();
  if (q) clients = clients.filter(c=>(c.name+' '+(c.address||'')).toLowerCase().includes(q));
  document.getElementById('clients-count').textContent = `${DB.getClients().length} aktywnych`;

  const list = document.getElementById('client-list');
  if (!clients.length) {
    list.innerHTML = `<div class="empty"><div class="ei">👥</div><div class="et">${q?'Brak wyników dla "'+esc(q)+'"':'Dodaj pierwszego klienta'}</div>${!q?'<div class="ea" onclick="openModal(\'modal-client\')">＋ Nowy klient</div>':''}</div>`;
    return;
  }
  const cnt = {};
  DB.getOrders().forEach(o=>{ cnt[o.clientId]=(cnt[o.clientId]||0)+1; });
  list.innerHTML = clients.map(c => {
    const n = cnt[c.id]||0;
    return `<div class="cc" onclick="openClient('${c.id}')">
      <div class="cc-av ${avatarCls(c.name)}">${initials(c.name)}</div>
      <div class="cc-info">
        <div class="cc-name">${esc(c.name)}</div>
        <div class="cc-addr">${esc(c.address||'Brak adresu')}</div>
        <div class="cc-tags">
          ${n?`<span class="tag green">${n} ${n===1?'zlecenie':n<5?'zlecenia':'zleceń'}</span>`:''}
          ${c.notes?'<span class="tag rose">⚠️ Uwagi</span>':''}
        </div>
      </div>
      <div class="oc-arr">›</div>
    </div>`;
  }).join('');
}

/* ════════════════════════════════════════
   RENDER: TEAM STATS
════════════════════════════════════════ */
function renderTeamStats() {
  const now   = new Date();
  const month = `${now.getFullYear()}-${String(now.getMonth()+1).padStart(2,'0')}`;
  const all   = DB.getOrders();
  const monthly  = all.filter(o=>o.date&&o.date.startsWith(month));
  const done     = monthly.filter(o=>o.status==='dn').length;
  const upcoming = all.filter(o=>o.date>=todayStr()&&o.status!=='dn').length;
  document.getElementById('team-stats').innerHTML = `
    <div class="stat rs"><div class="stat-num">${monthly.length}</div><div class="stat-lbl">Miesiąc</div></div>
    <div class="stat gn"><div class="stat-num">${done}</div><div class="stat-lbl">Zrobione</div></div>
    <div class="stat"><div class="stat-num">${upcoming}</div><div class="stat-lbl">Nadchodzą</div></div>`;
}

/* ════════════════════════════════════════
   RENDER: NOTES
════════════════════════════════════════ */
function renderNotes() {
  const notes = DB.getNotes();
  const el    = document.getElementById('notes-list');
  if (!notes.length) {
    el.innerHTML = `<div class="empty" style="padding:24px 20px"><div class="ei">📝</div><div class="et">Brak notatek</div><div class="ea" onclick="openModal('modal-note')">＋ Nowa notatka</div></div>`;
    return;
  }
  el.innerHTML = notes.map(n => {
    const d = new Date(n.createdAt);
    const ds = `${d.getDate()}.${String(d.getMonth()+1).padStart(2,'0')}.${d.getFullYear()}`;
    return `<div class="note-item" onclick="confirmDeleteNote('${n.id}')">
      <div class="note-t">${esc(n.title)}</div>
      ${n.body?`<div class="note-b">${esc(n.body)}</div>`:''}
      <div class="note-d">${ds} · Kliknij by usunąć</div>
    </div>`;
  }).join('');
}

/* ════════════════════════════════════════
   OPEN ORDER DETAIL
════════════════════════════════════════ */
function openOrder(id) {
  _currentOrderId = id;
  const o  = DB.getOrder(id); if (!o) return;
  const cl = DB.getClient(o.clientId);
  const s  = STATUS[o.status]||STATUS.pl;

  document.getElementById('order-chip').textContent  = `${s.icon} ${s.label}`;
  document.getElementById('order-title').textContent = cl ? cl.name : 'Nieznany klient';
  document.getElementById('order-sub').textContent   = `📅 ${datePL(o.date)}  ·  ⏰ ${o.time}`;

  // status buttons
  document.querySelectorAll('#order-status-grid .sbtn').forEach(b => {
    b.className = 'sbtn' + (b.dataset.s===o.status ? ' a-'+o.status : '');
  });

  // client card
  const cc = document.getElementById('order-client-card');
  cc.innerHTML = `<div class="icard-hd">🏠 Dane klienta</div>` + (cl ? `
    <div class="irow"><span class="ik">Imię</span><span class="iv">${esc(cl.name)}</span></div>
    ${cl.phone?`<div class="irow"><span class="ik">Telefon</span><span class="iv blue">${esc(cl.phone)}</span></div>`:''}
    ${cl.intercom?`<div class="irow"><span class="ik">Domofon</span><span class="iv code">${esc(cl.intercom)}</span></div>`:''}
    ${cl.notes?`<div class="irow"><span class="ik">Uwagi</span><span class="iv rose">⚠️ ${esc(cl.notes)}</span></div>`:''}
  ` : `<div class="irow"><span class="ik" style="color:var(--t3)">Brak danych klienta</span></div>`);

  // map
  const mw = document.getElementById('order-map-wrap');
  mw.innerHTML = cl&&cl.address
    ? `<a class="map-btn" href="https://maps.google.com/?q=${encodeURIComponent(cl.address)}" target="_blank">
        <span class="map-ico">📍</span>
        <div class="map-txt"><div class="mt1">Otwórz w Google Maps</div><div class="mt2">${esc(cl.address)}</div></div>
        <span class="map-arr">↗</span></a>` : '';

  // desc
  document.getElementById('order-desc-card').innerHTML = `<div class="icard-hd">📝 Opis</div>
    <div class="irow" style="display:block;padding:12px 15px">
      <span style="font-size:13px;color:var(--t2);line-height:1.6">${esc(o.desc||'Brak opisu')}</span>
    </div>`;

  refreshMainBtn(o.status);
  openSub('sub-order');
}

function refreshMainBtn(status) {
  const btn = document.getElementById('order-main-btn');
  const MAP = {
    pl:{ t:'✅ Potwierdź', cls:'indigo' },
    co:{ t:'🔄 Rozpocznij', cls:'indigo' },
    ip:{ t:'🏁 Zakończ zlecenie', cls:'rose-btn' },
    dn:{ t:'✓ Zakończone', cls:'ghost' }
  };
  const a = MAP[status]||MAP.pl;
  btn.textContent = a.t;
  btn.className = `bigbtn ${a.cls}`;
}

function setOrderStatus(s, btn) {
  if (!_currentOrderId) return;
  DB.updateOrder(_currentOrderId, { status:s });
  document.querySelectorAll('#order-status-grid .sbtn').forEach(b => {
    b.className = 'sbtn' + (b.dataset.s===s ? ' a-'+s : '');
  });
  const sm = STATUS[s];
  document.getElementById('order-chip').textContent = `${sm.icon} ${sm.label}`;
  refreshMainBtn(s);
  renderOrders(); renderDateStrip();
  toast(`Status: ${sm.label}`, 'success');
}

function advanceStatus() {
  const o = DB.getOrder(_currentOrderId);
  if (!o||o.status==='dn') return;
  const next = STATUS_NEXT[o.status];
  setOrderStatus(next, document.querySelector(`#order-status-grid .sbtn[data-s="${next}"]`));
}

function editCurrentOrder() {
  const o = DB.getOrder(_currentOrderId); if (!o) return;
  document.getElementById('f-order-id').value     = o.id;
  document.getElementById('modal-order-title').textContent = 'Edytuj zlecenie';
  document.getElementById('f-order-client').value = o.clientId;
  document.getElementById('f-order-date').value   = o.date;
  document.getElementById('f-order-time').value   = o.time;
  document.getElementById('f-order-status').value = o.status;
  document.getElementById('f-order-desc').value   = o.desc||'';
  populateClientSelect(o.clientId);
  openModal('modal-order');
}

function deleteCurrentOrder() {
  if (!confirm('Usunąć to zlecenie?')) return;
  DB.deleteOrder(_currentOrderId);
  closeSub('sub-order');
  renderOrders(); renderDateStrip();
  toast('Zlecenie usunięte');
}

/* ════════════════════════════════════════
   OPEN CLIENT DETAIL
════════════════════════════════════════ */
function openClient(id) {
  _currentClientId = id;
  const c = DB.getClient(id); if (!c) return;
  const orders = DB.getOrdersByClient(id);

  document.getElementById('client-chip').textContent  = `${orders.length} ${orders.length===1?'zlecenie':orders.length<5?'zlecenia':'zleceń'}`;
  document.getElementById('client-title').textContent = c.name;
  document.getElementById('client-sub').textContent   = c.phone||c.address||'';

  // contact
  document.getElementById('client-contact-card').innerHTML = `
    <div class="icard-hd">📞 Dane kontaktowe<span class="icard-edit" onclick="editCurrentClient()">✏️ Edytuj</span></div>
    ${c.phone?`<div class="irow"><span class="ik">Telefon</span><span class="iv blue">${esc(c.phone)}</span></div>`:''}
    ${c.address?`<div class="irow"><span class="ik">Adres</span><span class="iv">${esc(c.address)}</span></div>`:''}
    ${c.intercom?`<div class="irow"><span class="ik">Domofon</span><span class="iv code">${esc(c.intercom)}</span></div>`:''}`;

  // map
  document.getElementById('client-map-wrap').innerHTML = c.address
    ? `<a class="map-btn" href="https://maps.google.com/?q=${encodeURIComponent(c.address)}" target="_blank">
        <span class="map-ico">📍</span>
        <div class="map-txt"><div class="mt1">Otwórz w Google Maps</div><div class="mt2">${esc(c.address)}</div></div>
        <span class="map-arr">↗</span></a>` : '';

  // notes
  const nw = document.getElementById('client-notes-wrap');
  const ng = document.getElementById('client-notes-gap');
  if (c.notes) {
    nw.innerHTML = `<div class="icard"><div class="icard-hd">⚠️ Ważne uwagi</div>
      <div class="irow" style="display:block;padding:12px 15px">
        <span class="iv rose" style="display:block;text-align:left;font-size:13px;line-height:1.6">${esc(c.notes)}</span>
      </div></div>`;
    ng.innerHTML = '<div class="gap"></div>';
  } else {
    nw.innerHTML = ''; ng.innerHTML = '';
  }

  // history
  const hc = document.getElementById('client-history-card');
  hc.innerHTML = `<div class="icard-hd">📋 Historia zleceń (${orders.length})</div>` +
    (orders.length ? orders.slice(0,6).map(o=>{
      const s=STATUS[o.status]||STATUS.pl;
      return `<div class="irow tap" onclick="openOrder('${o.id}')">
        <div><div style="font-size:13px;font-weight:600">${datePL(o.date)} · ${esc(o.time)}</div>
        <div style="font-size:11px;color:var(--t2);margin-top:1px">${esc(o.desc||'Brak opisu')}</div></div>
        <span class="badge ${s.cls}">${s.label}</span>
      </div>`;
    }).join('')+(orders.length>6?`<div class="irow"><span class="ik" style="color:var(--t3)">…i ${orders.length-6} więcej</span></div>`:'')
    : `<div class="irow"><span class="ik" style="color:var(--t3)">Brak zleceń</span></div>`);

  document.getElementById('client-new-order-btn').textContent = `＋ Nowe zlecenie dla ${c.name.split(' ')[0]}`;
  document.getElementById('client-new-order-btn').onclick = () => openOrderModalForClient(id);

  openSub('sub-client');
}

function editCurrentClient() {
  const c = DB.getClient(_currentClientId); if (!c) return;
  document.getElementById('f-client-id').value            = c.id;
  document.getElementById('modal-client-title').textContent = 'Edytuj klienta';
  document.getElementById('f-client-name').value          = c.name||'';
  document.getElementById('f-client-addr').value          = c.address||'';
  document.getElementById('f-client-phone').value         = c.phone||'';
  document.getElementById('f-client-intercom').value      = c.intercom||'';
  document.getElementById('f-client-notes').value         = c.notes||'';
  openModal('modal-client');
}

function deleteCurrentClient() {
  const c = DB.getClient(_currentClientId);
  if (!confirm(`Usunąć klienta „${c?.name}"?\nWszystkie zlecenia tego klienta zostaną usunięte.`)) return;
  DB.deleteClient(_currentClientId);
  closeSub('sub-client');
  renderClients(); renderOrders(); renderDateStrip();
  toast('Klient usunięty');
}

/* ════════════════════════════════════════
   SAVE FORMS
════════════════════════════════════════ */
function saveClient() {
  const name = document.getElementById('f-client-name').value.trim();
  if (!name) { toast('Wpisz imię lub nazwę klienta', 'error'); return; }
  const data = {
    name,
    address:  document.getElementById('f-client-addr').value.trim(),
    phone:    document.getElementById('f-client-phone').value.trim(),
    intercom: document.getElementById('f-client-intercom').value.trim(),
    notes:    document.getElementById('f-client-notes').value.trim()
  };
  const editId = document.getElementById('f-client-id').value;
  if (editId) {
    DB.updateClient(editId, data);
    closeModal('modal-client');
    renderClients(); populateClientSelect();
    // refresh subview if open
    if (document.getElementById('sub-client').classList.contains('open')) openClient(editId);
    toast('✓ Dane klienta zaktualizowane', 'success');
  } else {
    DB.addClient(data);
    closeModal('modal-client');
    renderClients(); populateClientSelect();
    toast(`✓ Dodano: ${name}`, 'success');
  }
}

function saveOrder() {
  const clientId = document.getElementById('f-order-client').value;
  const date     = document.getElementById('f-order-date').value;
  if (!clientId) { toast('Wybierz klienta', 'error'); return; }
  if (!date)     { toast('Wybierz datę', 'error'); return; }
  const data = {
    clientId,
    date,
    time:   document.getElementById('f-order-time').value || '09:00',
    status: document.getElementById('f-order-status').value,
    desc:   document.getElementById('f-order-desc').value.trim()
  };
  const editId = document.getElementById('f-order-id').value;
  if (editId) {
    DB.updateOrder(editId, data);
    closeModal('modal-order');
    _selectedDate = data.date;
    renderOrders(); renderDateStrip(); renderTeamStats();
    if (document.getElementById('sub-order').classList.contains('open')) openOrder(editId);
    toast('✓ Zlecenie zaktualizowane', 'success');
  } else {
    DB.addOrder(data);
    closeModal('modal-order');
    _selectedDate = data.date;
    renderOrders(); renderDateStrip(); renderTeamStats();
    toast('✓ Zlecenie dodane', 'success');
  }
}

function saveNote() {
  const title = document.getElementById('f-note-title').value.trim();
  if (!title) { toast('Wpisz tytuł notatki', 'error'); return; }
  DB.addNote({ title, body: document.getElementById('f-note-body').value.trim() });
  document.getElementById('f-note-title').value = '';
  document.getElementById('f-note-body').value  = '';
  closeModal('modal-note');
  renderNotes();
  toast('✓ Notatka zapisana', 'success');
}

function confirmDeleteNote(id) {
  if (!confirm('Usunąć tę notatkę?')) return;
  DB.deleteNote(id); renderNotes();
  toast('Notatka usunięta');
}

/* ════════════════════════════════════════
   MODAL HELPERS
════════════════════════════════════════ */
function openModal(id) {
  if (id==='modal-order') {
    const editId = document.getElementById('f-order-id').value;
    if (!editId) {
      document.getElementById('modal-order-title').textContent = 'Nowe zlecenie';
      document.getElementById('f-order-date').value    = _selectedDate;
      document.getElementById('f-order-time').value    = '09:00';
      document.getElementById('f-order-status').value  = 'pl';
      document.getElementById('f-order-desc').value    = '';
      populateClientSelect();
      document.getElementById('f-order-client').value  = '';
    }
  }
  if (id==='modal-client') {
    const editId = document.getElementById('f-client-id').value;
    if (!editId) {
      document.getElementById('modal-client-title').textContent = 'Nowy klient';
      ['f-client-name','f-client-addr','f-client-phone','f-client-intercom','f-client-notes']
        .forEach(f => document.getElementById(f).value = '');
    }
  }
  const el = document.getElementById(id);
  el.style.display = 'flex';
  requestAnimationFrame(() => el.classList.add('open'));
}

function closeModal(id) {
  const el = document.getElementById(id);
  el.classList.remove('open');
  // Czyść ID natychmiast — nie po timeoucie
  const fid = el.querySelector('[id^="f-"][id$="-id"]');
  if (fid) fid.value = '';
  const mt = el.querySelector('.modal-title');
  if (mt) {
    if (id === 'modal-order')  mt.textContent = 'Nowe zlecenie';
    if (id === 'modal-client') mt.textContent = 'Nowy klient';
  }
  setTimeout(() => { el.style.display = 'none'; }, 280);
}

function overlayClose(e, id) {
  if (e.target===document.getElementById(id)) closeModal(id);
}

function openOrderModalForClient(clientId) {
  document.getElementById('f-order-id').value = '';
  openModal('modal-order');
  document.getElementById('f-order-client').value = clientId;
}

function populateClientSelect(selectedId) {
  const sel = document.getElementById('f-order-client');
  const clients = DB.getClients().sort((a,b)=>a.name.localeCompare(b.name,'pl'));
  sel.innerHTML = '<option value="">— Wybierz klienta —</option>' +
    clients.map(c=>`<option value="${c.id}"${c.id===selectedId?' selected':''}>${esc(c.name)}</option>`).join('');
}

/* ════════════════════════════════════════
   NAV & SUBVIEWS
════════════════════════════════════════ */
function switchView(id, el) {
  document.querySelectorAll('.subview').forEach(s => s.classList.remove('open'));
  document.querySelectorAll('.modal-overlay').forEach(m => { m.classList.remove('open'); m.style.display='none'; });
  document.querySelectorAll('.view').forEach(v => v.classList.remove('active'));
  document.querySelectorAll('.ni').forEach(n => n.classList.remove('on'));
  document.getElementById(id).classList.add('active');
  el.classList.add('on');
  if (id==='v-sched')   { renderOrders(); renderDateStrip(); }
  if (id==='v-clients') renderClients();
  if (id==='v-team')    renderTeamStats();
  if (id==='v-office')  renderNotes();
}

function openSub(id) {
  document.getElementById(id).classList.add('open');
}

function closeSub(id) {
  document.getElementById(id).classList.remove('open');
}

/* ════════════════════════════════════════
   TOAST
════════════════════════════════════════ */
let _tt;
function toast(msg, type='') {
  const el = document.getElementById('toast');
  el.textContent = msg;
  el.className = 'toast show' + (type?' '+type:'');
  clearTimeout(_tt);
  _tt = setTimeout(()=>el.className='toast', 2800);
}

/* ════════════════════════════════════════
   SOS — GPS + alert
════════════════════════════════════════ */
function triggerSOS() {
  toast('📍 Pobieranie lokalizacji GPS…');
  const send = loc => {
    toast('🆘 Alert SOS wysłany!', 'error');
    const info = loc
      ? `Lokalizacja GPS:\n${loc}\nhttps://maps.google.com/?q=${loc}`
      : 'Lokalizacja GPS niedostępna.';
    setTimeout(()=>alert(`🆘 SOS WYSŁANY\n\nDo: +48 519 404 678\n\n${info}\n\n[Production: zastąp fetch() do Twilio SMS API]`), 200);
  };
  if (navigator.geolocation) {
    navigator.geolocation.getCurrentPosition(
      p => send(`${p.coords.latitude.toFixed(5)},${p.coords.longitude.toFixed(5)}`),
      ()  => send(null),
      { timeout:6000, enableHighAccuracy:true }
    );
  } else { send(null); }
}

/* ════════════════════════════════════════
   INIT
════════════════════════════════════════ */
seedIfEmpty();
renderDateStrip();
renderOrders();
renderClients();
renderTeamStats();
renderNotes();
populateClientSelect(); // po seedzie — klienci już istnieją
</script>
